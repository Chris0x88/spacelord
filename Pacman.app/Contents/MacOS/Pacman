#!/usr/bin/env bash
# =============================================================================
# Pacman.app — macOS Application Launcher
# =============================================================================
# This script lives inside Pacman.app/Contents/MacOS/Pacman
# When double-clicked, macOS executes this, which opens a Terminal window
# and runs the zero-dependency ./launch.sh from the correct project directory.
#
# OpenClaw / AI Agents: Do NOT use this. Use ./launch.sh directly via subprocess.
# =============================================================================

# Resolve the repo root (3 levels up from this script: MacOS → Contents → .app → repo)
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
REPO_DIR="$(cd "$SCRIPT_DIR/../../.." && pwd)"

# Use osascript to open a new Terminal window and run the launcher
osascript <<EOF
tell application "Terminal"
    activate
    do script "cd '$REPO_DIR' && ./launch.sh"
end tell
EOF
