# BTC Power Law Rebalancer Configuration
# =======================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control!

# =============================================================================
# REQUIRED
# =============================================================================

# Your Hedera account private key (hex string, no 0x prefix)
PRIVATE_KEY=your_private_key_here

# =============================================================================
# RPC CONFIGURATION
# =============================================================================

# Primary RPC endpoint (Railway RPC - no rate limits)
RPC_URL=https://hiero-json-rpc-relay-production.up.railway.app

# Fallback RPC endpoint (public, used if primary fails)
MAINNET_RPC_URL=https://mainnet.hashio.io/api

# =============================================================================
# TRADING SETTINGS
# =============================================================================

# Maximum slippage tolerance (0.5 = 0.5%)
SLIPPAGE_PERCENT=0.5

# Minimum trade size in USDC (prevents dust trades)
MIN_TRADE_USDC=1.0

# Only execute trades that are profitable after fees
REQUIRE_PROFIT=true

# =============================================================================
# REBALANCING SETTINGS
# =============================================================================

# How often to check for rebalancing (seconds)
# 3600 = hourly, 86400 = daily
REBALANCE_INTERVAL_SECONDS=3600

# Minimum deviation from target before rebalancing (percent)
# V3 UPDATE: 15% threshold (was 1%). Backtest shows 1.51x vs HODL with fewer trades.
REBALANCE_THRESHOLD_PERCENT=15.0

# Threshold for immediate rebalance on extreme moves (percent)
EXTREME_THRESHOLD_PERCENT=5.0

# =============================================================================
# OPTIONAL: INITIAL TARGET
# =============================================================================

# Initial BTC target percentage (0-100)
# If not set, uses Power Law calculation
# INITIAL_BTC_TARGET=50
