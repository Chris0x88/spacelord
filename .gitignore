# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
venv/
.venv/
.pytest_cache/

# Environment & secrets
.env
.env.*
!.env.template
.DS_Store

# IDE
.vscode/
.idea/
.claude/

# Node
node_modules/
package-lock.json

# Runtime artifacts
*.log
*.tmp
*.pid
.~lock*
daemon_output.log
tmp/
logs/
execution_records/
training_data/
FEEDBACK/

# Sensitive: chat/session archives may contain pasted .env contents
data/chat_archive/

# Virtual environments
pacman_env/

# Non-essential directories (keep root clean)
dashboard/
pitch_deck/
memory/
.agent/

# Dev workspace (pitch deck builds, website, scripts, backups)
dev/

# Branding assets (generated art, logos)
branding/

# Memory files (auto-generated by scripts)
MEMORY.md
memory/
*/MEMORY.md

# Per-user agent preferences (populate from openclaw/defaults/USER.md)
openclaw/USER.md

# Personal governance overrides (ships generic via data/templates/governance.template.json)
data/governance.json

# Local-only tests (not shipped to public repo)
tests/local/

# Personal openclaw automation (paths hardcoded to user's machine)
openclaw/scripts/

# Skill files are gitignored by default — but ship the agent skill
SKILL.md
!openclaw/skills/*/SKILL.md

# Template exceptions
!data/templates/*.template.json
!memory/*.template.md
!memory/*.template

# Backups
backups/

# Knowledge base (per CLAUDE.md, gitignored)
data/knowledge/

# Deprecated
deprecated/
pactui/
.superpowers/
